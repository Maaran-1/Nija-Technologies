# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Workforce Optimization Platform"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────────────
# NOTE: In Docker Compose, this is overridden by the service environment block.
DATABASE_URL=postgresql://wop_user:wop_secret@db:5432/wop_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── PostgreSQL container password ─────────────────────────────────────────────
POSTGRES_PASSWORD=wop_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a secure key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_SECURE_KEY_HERE
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Zoho OAuth ────────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost/api/v1/sync/zoho/callback
ZOHO_PORTAL_ID=your_zoho_portal_id

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# MUST be a valid 44-character Fernet key. The app will refuse to start if this is wrong.
ENCRYPTION_KEY=CHANGE_ME_GENERATE_FERNET_KEY_HERE

# ── Analytics Thresholds ──────────────────────────────────────────────────────
UTILIZATION_WINDOW_WEEKS=2
UTILIZATION_UNDERUTILIZED_THRESHOLD=60.0
UTILIZATION_OPTIMAL_MAX=85.0
UTILIZATION_OVERLOADED_MAX=110.0

# ── Recommendation Engine ─────────────────────────────────────────────────────
MAX_PROJECTED_UTILIZATION=90.0
MIN_IMPACT_SCORE=5.0
RECOMMENDATION_BATCH_SIZE=50

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (NOT a JSON array)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost,http://localhost:80

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Sync schedules (seconds) ──────────────────────────────────────────────────
FULL_SYNC_INTERVAL_SECONDS=3600
TASK_SYNC_INTERVAL_SECONDS=900
TIMESHEET_SYNC_INTERVAL_SECONDS=1800
